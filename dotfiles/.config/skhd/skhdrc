# leader key to access shortcuts
:: leader @
rcmd - space    ; leader
leader < escape ; default

# apps
leader < k : open -a Things3;  skhd --key escape
leader < c : open -a Calendar; skhd --key escape
leader < m : open -a Messages; skhd --key escape
leader < f : open -a Finder; skhd --key escape
leader < s : open -a Spotify;  skhd --key escape

# websites
leader < shift - g : open -a "Firefox Developer Edition" "https://github.com"; skhd --key escape
leader < shift - d : open -a "Firefox Developer Edition" "https://desmos.com/calculator"; skhd --key escape
leader < shift - c : open -a "Firefox Developer Edition" "https://claude.ai"; skhd --key escape
leader < shift - n : open -a "Firefox Developer Edition" "https://search.nixos.org/packages"; skhd --key escape
