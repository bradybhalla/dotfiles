{
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "overlay",
  "control-center-margin-top": 4,
  "control-center-margin-bottom": 6,
  "control-center-margin-right": 4,
  "widgets": [
    "title",
    "dnd",
    "mpris",
    "volume",
    "buttons-grid",
    "inhibitors",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 8
    },
    "volume": {
      "label": "Volume",
      "show-per-app": true
    },
    "inhibitors": {
      "text": "Inhibitors",
      "button-text": "Clear All",
      "clear-all-button": true
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "Screenshot",
          "command": "grim -g \"$(slurp)\" - | wl-copy"
        },
        {
          "label": "Color Picker",
          "command": "hyprpicker -a"
        },
        {
          "label": "Lock",
          "command": "loginctl lock-session"
        },
        {
          "label": "Reload Waybar",
          "command": "pkill -SIGUSR2 waybar"
        }
      ]
    }
  }
}
