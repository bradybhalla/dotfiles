<?xml version="1.0" encoding="UTF-8"?>
<!-- TODO: review new file (dropdown menu for the waybar nixos icon) -->
<interface>
  <object class="GtkMenu" id="menu">
    <child>
      <object class="GtkMenuItem" id="user">
        <property name="label">bradybhalla</property>
        <property name="sensitive">False</property>
      </object>
    </child>
    <child>
      <object class="GtkSeparatorMenuItem" id="sep1"/>
    </child>
    <child>
      <object class="GtkMenuItem" id="about">
        <property name="label">About This Computer</property>
      </object>
    </child>
    <child>
      <object class="GtkMenuItem" id="uptime">
        <property name="label">Uptime</property>
      </object>
    </child>
    <child>
      <object class="GtkSeparatorMenuItem" id="sep2"/>
    </child>
    <child>
      <object class="GtkMenuItem" id="logout">
        <property name="label">Log Out</property>
      </object>
    </child>
    <child>
      <object class="GtkMenuItem" id="reboot">
        <property name="label">Reboot</property>
      </object>
    </child>
    <child>
      <object class="GtkMenuItem" id="shutdown">
        <property name="label">Shut Down</property>
      </object>
    </child>
  </object>
</interface>
